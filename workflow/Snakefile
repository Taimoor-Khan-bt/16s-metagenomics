# =============================================================================
# Snakefile — QIIME 2 16S rRNA Pipeline
# =============================================================================
# All QIIME 2 steps run inside the official Docker image.
# No QIIME 2 conda installation required.
#
# Quick start:
#   1. bash setup.sh
#   2. Edit config/config.yaml  (paths + parameters)
#   3. Edit config/samples.tsv  (sample_id + r1 path per line)
#   4. Edit config/metadata.tsv (QIIME 2 metadata, #SampleID header)
#   5. snakemake --cores all
#
# Dry run (no Docker needed):
#   snakemake -n
# =============================================================================

import os
import pandas as pd

configfile: "config/config.yaml"

# ── Validate required config keys ────────────────────────────────────────────
for key in ["docker", "samples", "output_dir", "metadata", "classifier", "dada2", "diversity"]:
    if key not in config:
        raise ValueError(f"Missing required config key: '{key}'")

# ── Load sample sheet ─────────────────────────────────────────────────────────
SAMPLES_DF = pd.read_table(config["samples"], comment="#").set_index("sample_id", drop=False)
SAMPLES    = SAMPLES_DF.index.tolist()

if not SAMPLES:
    raise ValueError(f"No samples found in {config['samples']}")

OUT           = config["output_dir"]
ALPHA_METRICS = config["diversity"]["alpha_metrics"]
BETA_METRICS  = config["diversity"]["beta_metrics"]

# Extended analysis config (optional — only used by all_extended)
COLLAPSE_LEVELS = config.get("analysis", {}).get("collapse_levels", ["2", "3", "6"])
ANCOMBC_LEVELS  = config.get("analysis", {}).get("ancombc_levels", ["2", "6"])

# ── Include rule modules ───────────────────────────────────────────────────────
include: "rules/common.smk"
include: "rules/import.smk"
include: "rules/denoise.smk"
include: "rules/taxonomy.smk"
include: "rules/phylogeny.smk"
include: "rules/visualize.smk"
include: "rules/diversity.smk"
include: "rules/barplot.smk"
include: "rules/export.smk"
# ── Extended analysis rule modules ────────────────────────────────────────────
include: "rules/composition.smk"
include: "rules/statistics.smk"
include: "rules/differential.smk"
include: "rules/picrust.smk"

# ── Post-include variables (require OUT_VIZ defined in common.smk) ───────────
# Taxa processing config — drives filter_taxa rule and dual-plot inclusion
_TAXA_PROC = config.get("taxa_processing", {})
_DUAL_PLOT_OUTPUTS = (
    [
        f"{OUT_VIZ}/composition/composition_plots_raw.pdf",
        f"{OUT_VIZ}/differential/lefse_plots_raw.pdf",
        f"{OUT_VIZ}/picrust2/pathway_plots_raw.pdf",
    ]
    if _TAXA_PROC.get("generate_dual_plots", False)
    else []
)

# Krona HTML targets for all_extended
_KRONA_CFG       = config.get("krona", {})
_KRONA_LEVELS_SF = _KRONA_CFG.get("levels", ["2", "3", "6"])
_KRONA_NAMES_SF  = {"2": "phylum", "3": "class", "4": "order",
                    "5": "family", "6": "genus", "7": "species"}
_KRONA_HTMLS     = (
    [f"{OUT_VIZ}/composition/krona/krona_all_samples.html"] +
    [f"{OUT_VIZ}/composition/krona/krona_level{l}_{_KRONA_NAMES_SF.get(l, l)}.html"
     for l in _KRONA_LEVELS_SF]
)


rule all:
    input:
        # ── Core QIIME 2 artifacts ─────────────────────────────────────────
        f"{OUT}/sequences.qza",
        f"{OUT}/table.qza",
        f"{OUT}/rep_seqs.qza",
        f"{OUT}/dada2_stats.qza",
        f"{OUT}/taxonomy.qza",
        f"{OUT}/rooted_tree.qza",
        # ── Summary visualizations (→ visualizations/qc/ and taxonomy/) ────
        f"{OUT_VIZ}/qc/dada2_stats.qzv",
        f"{OUT_VIZ}/qc/table_summary.qzv",
        f"{OUT_VIZ}/qc/rep_seqs.qzv",
        f"{OUT_VIZ}/taxonomy/taxa_barplot.qzv",
        # ── Diversity QZVs (→ visualizations/diversity/) ───────────────────
        expand(f"{OUT_VIZ}/diversity/{{metric}}_correlation.qzv",
               metric=ALPHA_METRICS),
        # ── Exported flat files ────────────────────────────────────────────
        f"{OUT}/exported/feature_table/feature-table.tsv",
        f"{OUT}/exported/taxonomy/taxonomy.tsv",
        f"{OUT}/exported/tree/tree.nwk",
        f"{OUT}/exported/rep_seqs/dna-sequences.fasta",
        f"{OUT}/exported/dada2_stats/stats.tsv",
        expand(f"{OUT}/exported/alpha_diversity/{{metric}}/alpha-diversity.tsv",
               metric=ALPHA_METRICS),
        # ── Filtered feature table (no mito/chloro/unassigned) ───────────────────
        f"{OUT}/table_filtered.qza",
        f"{OUT}/exported/feature_table_filtered/feature-table.tsv",
        # ── Beta PCoA ordinations (used by core_plots) ────────────────────────────
        expand(f"{OUT}/exported/beta_diversity/{{beta_metric}}/ordination.txt",
               beta_metric=BETA_METRICS),
        # ── Bray-Curtis distance matrix (used by core_plots within/between boxplot)
        f"{OUT}/exported/beta_diversity/bray_curtis/distance_matrix.tsv",
        # ── Core PNGs (R from exported TSVs — no Docker) ─────────────────────────
        f"{OUT_VIZ}/qc/dada2_stats.png",
        f"{OUT_VIZ}/qc/read_depth.png",
        f"{OUT_VIZ}/taxonomy/taxonomy_barplot.png",
        f"{OUT_VIZ}/taxonomy/top_taxa_abundance.png",
        # ── Alpha diversity plots + statistics ────────────────────────────────────
        f"{OUT}/stats/alpha/alpha_statistics.tsv",
        f"{OUT}/stats/alpha/dunn_posthoc.tsv",
        f"{OUT_VIZ}/diversity/alpha_plots.pdf",
        f"{OUT_VIZ}/diversity/alpha_plots.png",
        f"{OUT_VIZ}/diversity/alpha_plots_glm.png",
        # ── Beta diversity plots + PERMANOVA statistics ───────────────────────────
        expand(f"{OUT}/stats/beta/{{beta_metric}}_distance_matrix.tsv",
               beta_metric=["bray_curtis", "weighted_unifrac"]),
        f"{OUT}/stats/beta/permanova_results.tsv",
        f"{OUT}/stats/beta/permanova_pairwise.tsv",
        f"{OUT_VIZ}/diversity/pcoa_plots.pdf",
        f"{OUT_VIZ}/diversity/pcoa_plots.png",
        f"{OUT_VIZ}/diversity/permdisp_plots.png",
# ── Target rule: full extended analysis (A–G) ─────────────────────────────────
# Run with: snakemake all_extended --cores all --snakefile workflow/Snakefile
rule all_extended:
    input:
        # ─ Base pipeline (inherited, includes alpha+beta plots) ───────────
        rules.all.input,
        # ─ A: Alpha diversity — group significance QZVs ───────────────────
        expand(f"{OUT_VIZ}/diversity/{{metric}}_group_significance.qzv",
               metric=ALPHA_METRICS),
        # ─ B: Beta diversity — PERMANOVA QZVs ─────────────────────────────
        expand(f"{OUT_VIZ}/diversity/{{beta_metric}}_permanova.qzv",
               beta_metric=BETA_METRICS),
        # ─ C: Composition analysis ─────────────────────────────────────────
        expand(f"{OUT}/composition/{{level}}_relfreq.tsv", level=COLLAPSE_LEVELS),
        expand(f"{OUT_VIZ}/composition/{{level}}_barplot.qzv", level=COLLAPSE_LEVELS),
        f"{OUT_VIZ}/composition/composition_plots.pdf",
        f"{OUT_VIZ}/composition/composition_barplot_panel.png",
        f"{OUT_VIZ}/composition/composition_heatmap_panel.png",
        f"{OUT_VIZ}/composition/composition_bubble_panel.png",
        f"{OUT_VIZ}/composition/composition_ranked_panel.png",
        f"{OUT_VIZ}/composition/composition_prevalence_panel.png",
        *_KRONA_HTMLS,
        # ─ D: Differential abundance ──────────────────────────────────────
        expand(f"{OUT_VIZ}/differential/ancombc_level{{level}}.qzv", level=ANCOMBC_LEVELS),
        expand(f"{OUT_VIZ}/differential/ancombc_level{{level}}_barplot.qzv", level=ANCOMBC_LEVELS),
        expand(f"{OUT}/differential/ancombc_level{{level}}.tsv", level=ANCOMBC_LEVELS),
        f"{OUT}/differential/lefse_results.tsv",
        f"{OUT_VIZ}/differential/lefse_plots.pdf",
        f"{OUT_VIZ}/differential/lefse_phylum_plots.pdf",
        f"{OUT_VIZ}/differential/lefse_phylum_plots.png",
        f"{OUT_VIZ}/differential/lefse_genus_plots.pdf",
        f"{OUT_VIZ}/differential/lefse_genus_plots.png",
        f"{OUT_VIZ}/differential/lefse_cladogram.pdf",
        f"{OUT_VIZ}/differential/lefse_cladogram.png",
        # ─ E: Core microbiome ─────────────────────────────────────────────
        f"{OUT_VIZ}/core_microbiome/core_features.qzv",
        f"{OUT}/core_microbiome/core_stats.tsv",
        f"{OUT_VIZ}/core_microbiome/core_plots.pdf",
        f"{OUT_VIZ}/core_microbiome/core_plots.png",
        f"{OUT_VIZ}/core_microbiome/core_upset.png",
        # ─ G: PICRUSt2 functional prediction ─────────────────────────────
        f"{OUT}/picrust2/pathway_differential.tsv",
        f"{OUT}/picrust2/nsti_summary.tsv",
        f"{OUT_VIZ}/picrust2/pathway_plots.pdf",
        f"{OUT_VIZ}/picrust2/pathway_plots.png",
        f"{OUT_VIZ}/picrust2/pathway_plots_heatmap.png",
        f"{OUT_VIZ}/picrust2/pathway_plots_raw.png",
        f"{OUT_VIZ}/picrust2/pathway_plots_raw_heatmap.png",
        # ─ H: Phylogenetic tree visualizations (ggtree) ───────────────────
        f"{OUT_VIZ}/phylogeny/01_tree_basic.pdf",
        f"{OUT_VIZ}/phylogeny/02_tree_abundance_heatmap.pdf",
        f"{OUT_VIZ}/phylogeny/03_tree_phylum_colorstrip.pdf",
        f"{OUT_VIZ}/phylogeny/04_tree_differential.pdf",
        f"{OUT_VIZ}/phylogeny/05_tree_circular.pdf",
        f"{OUT_VIZ}/phylogeny/01_tree_basic.png",
        f"{OUT_VIZ}/phylogeny/02_tree_abundance_heatmap.png",
        f"{OUT_VIZ}/phylogeny/03_tree_phylum_colorstrip.png",
        f"{OUT_VIZ}/phylogeny/04_tree_differential.png",
        f"{OUT_VIZ}/phylogeny/05_tree_circular.png",
        # ─ Dual raw-label PDFs (only when taxa_processing.generate_dual_plots: true)
        *_DUAL_PLOT_OUTPUTS,
